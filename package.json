{
  "name": "afh-contact",
  "type": "module",
  "version": "0.2.4",
  "private": true,
  "scripts": {
    "dev": "vitepress dev docs",
    "build": "vitepress build docs && node -e \"const fs=require('fs'); fs.copyFileSync('docs/feed.xml', 'docs/.vitepress/dist/feed.xml'); console.log('✅ feed.xml copied to dist');\"",
    "preview": "vitepress preview docs",
    "lint": "eslint .",
    "posts": "node .github/scripts/fetch-rss-articles.js",
    "pwa:icons": "node scripts/generate-pwa-icons.js",
    "pwa:screenshots": "node scripts/generate-screenshots.js",
    "pwa:generate-assets": "npm run pwa:icons && npm run pwa:screenshots",
    "pwa:preview": "npm run build && npm run preview"
  },
  "dependencies": {
    "@iconify/vue": "^5.0.0",
    "@vueuse/core": "^14.2.1",
    "parse-domain": "^8.3.0",
    "pinia": "^3.0.4",
    "rss-parser": "^3.13.0",
    "vitepress": "2.0.0-alpha.17",
    "vue": "^3.5.30",
    "vue-tippy": "^6.7.1"
  },
  "devDependencies": {
    "@antfu/eslint-config": "^7.7.3",
    "@types/node": "^25.6.0",
    "@zinkawaii/stylelint-config": "^0.4.0",
    "@zinkawaii/tsconfig": "^0.1.0",
    "eslint": "^10.0.3",
    "sharp": "^0.34.5",
    "stylelint": "^17.5.0",
    "vite-plugin-pwa": "^1.2.0",
    "workbox-window": "^7.4.0"
  },
  "pnpm": {
    "onlyBuiltDependencies": [
      "esbuild"
    ]
  }
}
